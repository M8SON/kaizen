# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model (default: claude-sonnet-4-5-20250929)
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Voice settings — STT model selection
#
# CPU and Hailo paths take separate Whisper variants because Hailo only
# has tiny/base HEFs published, while CPU via faster-whisper happily runs
# Whisper-small for materially better accuracy on Pi 5.
#
# Tiers: tiny | base | small | medium | large (larger = more accurate, slower)
# Auto-downloads on first run; CPU models cache to ~/.cache/huggingface/
# (faster-whisper) or ~/.cache/whisper/ (openai-whisper fallback).
WHISPER_MODEL_CPU=small             # faster-whisper model on CPU path
WHISPER_MODEL_HAILO=base            # Hailo HEF variant (only base/tiny published)

# Legacy single-model knob; kept for backwards compat. When set to a non-
# default value, it overrides WHISPER_MODEL_CPU. Always overrides
# WHISPER_MODEL_HAILO when that env var is unset.
# WHISPER_MODEL=base

ENABLE_TTS=true

# TTS backend selection
#   kokoro       — kokoro PyTorch package (default; works everywhere, slow on Pi)
#   kokoro-onnx  — same Kokoro voices via ONNX Runtime int8 — runs across all
#                  available CPU cores by default. Requires running
#                  scripts/download_kokoro_onnx.py once to fetch model files
#                  into ~/.miniclaw/models/kokoro-onnx/. Falls back to kokoro
#                  automatically if the assets are missing.
TTS_BACKEND=kokoro
# Override ONNX Runtime intra-op threads (default: all CPUs, 4 on Pi 5)
# TTS_ONNX_THREADS=4
# Pick fp32 (default, ~310MB) or int8 (~88MB) variant of the ONNX model.
# fp32 is the default after Pi 5 testing 2026-05-09 — ONNX Runtime's int8
# kernels for ARMv8.2 are not optimised for Cortex-A76, so int8 ran ~2x
# slower than fp32 there. Switch to int8 on x86_64 where int8 IS faster.
# KOKORO_ONNX_VARIANT=fp32

# Kokoro TTS voice — same voice names work for both backends.
# PyTorch kokoro auto-downloads to ~/.cache/huggingface/ on first run (~80MB).
# Requires: sudo apt install espeak-ng
# American English voices: af_heart (default), af_sky, am_adam, am_michael
# British English voices: bf_emma, bf_isabella, bm_george, bm_lewis
TTS_VOICE=af_heart

# Audio device selection — case-insensitive substring match against the
# device name reported by ALSA/PortAudio. Lets the same physical device get
# selected even when USB enumeration reshuffles card indices.
# Defaults match the bundled hardware (reSpeaker XVF3800 + KT USB DAC).
# MIC_DEVICE=Array
# SPEAKER_DEVICE=KT USB

SILENCE_THRESHOLD=1000
SILENCE_DURATION=2.0
# How long to wait for follow-up speech (seconds) before ending the conversation session
CONVERSATION_IDLE_TIMEOUT=8

# Container settings
CONTAINER_MEMORY=256m

# Skill prompt tuning
# SKILL_SELECT_TOP_K: how many skills get full instructions per request (default: 2)
# Lower = fewer tokens per request. Set to 1 for maximum token savings.
# Always-full skills (set-env-var, save-memory, install-skill) are never compacted.
SKILL_SELECT_TOP_K=2

# Memory backend
# MEMORY_BACKEND: vault | mempalace | auto
# `vault` keeps the existing markdown-note flow.
# `mempalace` injects MemPalace wake-up context into the system prompt.
# `auto` prefers MemPalace when installed and falls back to the markdown vault.
MEMORY_BACKEND=auto
MEMORY_RECALL_MAX_TOKENS=600
# Optional MemPalace settings
# MEMPALACE_PALACE_PATH=~/.mempalace/palace
# MEMPALACE_WING=wing_miniclaw
# MEMPALACE_SAVE_MEMORY=auto
# MEMPALACE_MEMORY_WING=wing_miniclaw
# MEMPALACE_MEMORY_ROOM=assistant-memory

# Tiered Intelligence (optional)
# When MICRO_TIER_ENABLED=true, trivial commands route to Claude Haiku with
# a slim prompt and top-K-filtered tools (sub-second, a few cents/turn);
# Sonnet handles complex / ambiguous / meta requests.
# Replaced the prior local-Ollama tier on 2026-05-08 — phi4-mini on Pi 5
# generates at 3-5 tok/s and timed out at 25s on typical responses.
# MICRO_TIER_ENABLED=false
# MICRO_TIER_MODEL=claude-haiku-4-5
# CLAUDE_ONLY_SKILLS=install-skill

# Skill API keys (optional - skills auto-disable if key is missing)
BRAVE_API_KEY=your_brave_api_key_here
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Wake word (openWakeWord — Wave 1, voice pipeline)
WAKE_WORD_MODEL=hey_jarvis         # openWakeWord prebuilt model name
WAKE_WORD_THRESHOLD=0.5            # 0.0–1.0 activation confidence

# VAD backend (Wave 2 — voice pipeline)
VAD_BACKEND=silero                 # silero | rms (fallback)
VAD_THRESHOLD=0.5                  # silero speech probability cutoff
VAD_MIN_SILENCE_MS=700             # ms of silence before endpointing

# Legacy (consulted only when VAD_BACKEND=rms)
# SILENCE_THRESHOLD=1000
# SILENCE_DURATION=2.0

# LLM → TTS streaming (Wave 4)
# When true, Claude's text deltas stream into Kokoro sentence-by-sentence
# so first audio plays ~1-2s after Claude starts responding instead of
# waiting for the full response (Pi 5 buffered first-audio measured at
# 7-23s on 2026-05-08). Set to false to revert to buffered behaviour.
LLM_STREAM_TO_TTS=true

# Spotify (optional — enables the `spotify` skill as the default music backend)
# Setup:
#   1. Register a Spotify Developer app at developer.spotify.com.
#   2. Set both env vars below from the app dashboard.
#   3. Add http://localhost:8888/callback to the app's Redirect URIs.
#   4. Run `python scripts/spotify_login.py` once to do the OAuth dance.
#   5. On the Pi: `sudo apt install librespot`, then in phone Spotify open
#      Connect and tap the Pi as a device once to pair librespot.
# When unset, the skill self-skips (skill_loader.skipped_skills) and
# SoundCloud remains the only music backend.
# SPOTIFY_CLIENT_ID=your_spotify_client_id_here
# SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
# SPOTIFY_REDIRECT_URI=http://localhost:8888/callback
# Pin playback to one Connect device (case-insensitive name match against the
# device list). When set, the skill returns "Connect device unavailable"
# instead of falling back to other account devices like a TV or phone.
# Match the librespot LIBRESPOT_NAME on the Pi (raspotify default: MiniClaw).
# SPOTIFY_DEVICE_NAME=MiniClaw
